#!/usr/bin/env bash
set -e

DOCKER_IMAGE="aegis-ajax-dev"
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}=== Pre-push CI check ===${NC}"

# Build Docker image (same as CI)
echo -e "${YELLOW}[1/6] Building Docker image...${NC}"
docker build -f Dockerfile.dev -t "$DOCKER_IMAGE" . -q > /dev/null
echo -e "${GREEN}  ✓ Docker image built${NC}"

# Lint
echo -e "${YELLOW}[2/6] Linting...${NC}"
docker run --rm "$DOCKER_IMAGE" ruff check .
echo -e "${GREEN}  ✓ Lint passed${NC}"

# Format check
echo -e "${YELLOW}[3/6] Format check...${NC}"
docker run --rm "$DOCKER_IMAGE" ruff format --check .
echo -e "${GREEN}  ✓ Format OK${NC}"

# Type check
echo -e "${YELLOW}[4/6] Type check...${NC}"
docker run --rm "$DOCKER_IMAGE" mypy custom_components/aegis_ajax/ --ignore-missing-imports --exclude 'proto/'
echo -e "${GREEN}  ✓ Type check passed${NC}"

# Dead code
echo -e "${YELLOW}[5/6] Dead code analysis...${NC}"
docker run --rm "$DOCKER_IMAGE" vulture custom_components/aegis_ajax/ vulture_whitelist.py --exclude custom_components/aegis_ajax/proto/
echo -e "${GREEN}  ✓ No dead code${NC}"

# Tests
echo -e "${YELLOW}[6/6] Running tests...${NC}"
docker run --rm "$DOCKER_IMAGE" pytest tests/unit/ -v --cov=custom_components/aegis_ajax --cov-fail-under=80 --cov-report=term-missing
echo -e "${GREEN}  ✓ Tests passed${NC}"

echo -e "${GREEN}=== All CI checks passed! ===${NC}"
